library(shiny); runApp('losowanie.r')
#| echo: false
#| message: false
#| warning: false
library(shiny)
# 1. Baza pytań
baza_pytan <- c(
"1. Czym się różni test jednowymiarowy od testu wielowymiarowego?",
"2. Wymień znane Ci dwa testy wielowymiarowe.",
"3. Do czego służy test MANOVA i na jakiej zasadzie działa?",
"4. Wymień różnice pomiędzy regresją wieloraką a analizą kanoniczną.",
"5. Opisz zasadę działania analizy kanonicznej.",
"6. Czym charakteryzują się kolejne pary zmiennych kanonicznych?",
"7. Jak testujemy istotność statystyczną par kanonicznych?"
)
# 2. Interfejs (UI)
ui <- fluidPage(
sidebarLayout(
sidebarPanel(
checkboxInput(inputId = "przelosuj",
label = "Przelosuj pytanie",
value = FALSE),
actionButton(inputId = "losuj_btn",
label = "Wylosuj",
class = "btn-primary")
),
mainPanel(
uiOutput("wylosowane_pytania")
)
)
)
# 3. Logika (Server)
server <- function(input, output, session) {
wynik <- reactiveVal(character(0))
observeEvent(input$losuj_btn, {
ile_wylosowac <- min(2, length(baza_pytan))
wylosowane <- sample(baza_pytan, size = ile_wylosowac, replace = FALSE)
wynik(wylosowane)
})
output$wylosowane_pytania <- renderUI({
if (length(wynik()) == 0) {
return(HTML("<p style='color: grey; font-size: 16px;'>Kliknij <b>Wylosuj</b>, aby wylosować zestaw pytań.</p>"))
}
HTML(paste0("<div style='font-size: 18px; line-height: 1.5;'>",
paste(wynik(), collapse = "<br><br>"),
"</div>"))
})
}
# 4. Wywołanie aplikacji
shinyApp(ui = ui, server = server)
